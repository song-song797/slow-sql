APP_ENV=local
API_KEY=dev-api-key

ES_URL=http://127.0.0.1:9200
ES_INDEX_PATTERN=triangle-mysql-*

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=slow_sql
DB_PASSWORD=slow_sql
DB_NAME=slow_sql_db

REPORT_PROVIDER=local_stub
REPORT_API_BASE_URL=http://127.0.0.1:18080
WORKFLOW_ID=

# 外接 API1 工作流示例：
# REPORT_PROVIDER=api1_workflow
# REPORT_API_BASE_URL=http://your-host/api/v2/workflow/invoke
# WORKFLOW_ID=your-workflow-id

METADATA_AUTO_FETCH_ENABLED=true
METADATA_AUTO_FETCH_DB_TYPE=mysql
METADATA_AUTO_FETCH_USERNAME=slow_sql
METADATA_AUTO_FETCH_PASSWORD=slow_sql
METADATA_AUTO_FETCH_MAX_WORKERS=4
METADATA_AUTO_FETCH_MAX_TABLES_PER_REQUEST=8
METADATA_AUTO_FETCH_TOTAL_TIMEOUT_SECONDS=6
METADATA_AUTO_FETCH_CONNECT_TIMEOUT_SECONDS=3
METADATA_AUTO_FETCH_READ_TIMEOUT_SECONDS=3
METADATA_AUTO_FETCH_WRITE_TIMEOUT_SECONDS=3
