# App Configuration
APP_ENV=local
API_KEY=dev-api-key

# Elasticsearch Configuration
ES_URL=http://127.0.0.1:9200
ES_INDEX_PATTERN=triangle-mysql-*
ES_USERNAME=
ES_PASSWORD=
ES_USE_SSL=false

# MySQL Database Configuration
DATABASE_URL=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=slow_sql
DB_PASSWORD=slow_sql
DB_NAME=slow_sql_db

# Report Generation Configuration
REPORT_PROVIDER=api1_workflow
REPORT_API_BASE_URL=http://your-host/api/v2/workflow/invoke
REPORT_API_TIMEOUT=300
WORKFLOW_ID=your-workflow-id
