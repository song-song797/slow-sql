#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
COMPOSE_FILE="$ROOT_DIR/docker-compose.local.yml"

log() {
  printf '[run-project] %s\n' "$1"
}

fail() {
  printf '[run-project] %s\n' "$1" >&2
  exit 1
}

require_command() {
  local command_name="$1"
  command -v "$command_name" >/dev/null 2>&1 || fail "缺少命令: $command_name"
}

wait_for_http() {
  local url="$1"
  local label="$2"
  local timeout_seconds="$3"
  local elapsed=0

  while (( elapsed < timeout_seconds )); do
    if curl -fsS "$url" >/dev/null 2>&1; then
      return 0
    fi
    sleep 2
    elapsed=$((elapsed + 2))
  done

  fail "$label 未在 ${timeout_seconds}s 内就绪"
}

main() {
  require_command docker
  require_command curl
  [[ -f "$COMPOSE_FILE" ]] || fail "未找到 compose 文件: $COMPOSE_FILE"

  log "启动完整容器化环境..."
  docker compose -f "$COMPOSE_FILE" up -d --build

  wait_for_http "http://127.0.0.1:10800/health" "后端" 120
  wait_for_http "http://127.0.0.1:3000" "前端" 120

  log "Frontend: http://127.0.0.1:3000"
  log "Backend:  http://127.0.0.1:10800/docs"
  log "Compose:  docker compose -f docker-compose.local.yml ps"
}

main "$@"
